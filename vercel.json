{
    "buildCommand": "prisma generate && npm run build",
    "builds": [
        {
            "src": "./src/index.ts",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "dest": "/src/index.ts",
            "src": "/(.*)"
        }
    ],
    "version": 2
}