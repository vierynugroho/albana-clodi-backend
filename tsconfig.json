{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"paths": {
			"@/*": ["*"]
		},
		"moduleResolution": "Node",
		"outDir": "./dist",
    	"baseUrl": "./",
		"importsNotUsedAsValues": "remove",
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["node"],
		"typeRoots": ["./node_modules/@types", "./types"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
